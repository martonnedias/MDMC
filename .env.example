# ===========================================
# MD Solution - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite .env ou .env.local com valores reais!

# Google Gemini AI (para geração de conteúdo do blog)
VITE_GEMINI_API_KEY=

# EmailJS (para envio de e-mails de contato)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_TEMPLATE_CLIENT_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Supabase (banco de dados e autenticação)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin Access Control (e-mails separados por vírgula)
VITE_ADMIN_EMAILS=
